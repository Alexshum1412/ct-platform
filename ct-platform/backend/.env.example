# ============================================
# CT-Platform Backend Environment Variables
# ============================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ct_platform?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
FRONTEND_URL="http://localhost:5173"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

VK_CLIENT_ID=""
VK_CLIENT_SECRET=""

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@ct-platform.by"

# Redis (for caching and sessions)
REDIS_URL="redis://localhost:6379"

# reCAPTCHA
RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# Payment (for Premium)
PAYMENT_PROVIDER=""
PAYMENT_API_KEY=""
# Платёжный провайдер ещё не подключён. POST /api/subscription активирует Premium
# в демо-режиме (без оплаты). В production это РАЗРЕШЕНО только при ALLOW_DEMO_PREMIUM=true
# (иначе 503). Снимите флаг, когда появится реальная проверка оплаты на бэкенде.
ALLOW_DEMO_PREMIUM="false"

# CDN / File Storage
CDN_URL=""
UPLOAD_DIR="./uploads"

# Analytics
ANALYTICS_ENABLED="true"

# Security
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW="900" # 15 minutes in seconds

# Environment
NODE_ENV="development"
PORT="3000"

# Пиксель-арт: секрет для месячной cron-архивации полотна.
# Запуск 1-го числа в 00:00: POST /api/cron/pixel-archive с заголовком
# x-cron-secret: <значение> (Render Cron Job, Vercel Cron или внешний планировщик).
# Если не задан — в dev разрешено без секрета; тот же переход выполняется лениво.
CRON_SECRET=""
