# next-auth@4 declares an OPTIONAL peer on nodemailer@^7, but the project uses
# nodemailer@6 (email provider is unused — auth is Credentials/JWT). Strict npm
# (Node 20+/22+) errors with ERESOLVE on this optional peer, so relax resolution.
legacy-peer-deps=true
# Render sets NODE_ENV=production, which makes `npm install` skip devDependencies.
# include=dev forces them in (belt-and-suspenders; build tools are also in deps now).
include=dev
